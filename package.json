{
  "name": "twotter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "typecheck": "turbo typecheck",
    "db:push": "bun --env-file=../../.env run --cwd packages/db push",
    "db:seed": "bun run --cwd packages/db seed",
    "db:studio": "bun --env-file=../../.env run --cwd packages/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docs": "cabinet dev --port 4000 --previewPort 4001",
    "docs:build": "cabinet build"
  },
  "devDependencies": {
    "@cabinetdocs/cli": "0.1.0",
    "@cabinetdocs/core": "0.1.0",
    "@cabinetdocs/preview-react": "0.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@aws-sdk/client-s3": "3.1037.0",
    "@databuddy/sdk": "2.4.11",
    "@heroicons/react": "2.2.0",
    "@octokit/request": "10.0.8",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/eslint-config": "0.3.4",
    "@tanstack/react-router": "1.168.25",
    "@tanstack/react-start": "1.167.50",
    "@tanstack/router-generator": "1.166.36",
    "@tanstack/router-plugin": "1.167.28",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "better-auth": "1.6.9",
    "chess.js": "1.4.0",
    "drizzle-orm": "0.45.2",
    "eslint": "9.39.4",
    "hono": "4.12.15",
    "ioredis": "5.10.1",
    "pg-boss": "10.4.2",
    "pino": "9.14.0",
    "pino-pretty": "13.1.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "0.33.5",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
