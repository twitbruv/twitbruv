{
  "name": "feed-ranker",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --env-file=../../.env --watch src/index.ts",
    "start": "bun run build && bun run --env-file=../../.env dist/index.js",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "@workspace/types": "workspace:*",
    "hono": "^4.7.11",
    "ioredis": "^5.8.0",
    "pino": "^9.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.3.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.1.0",
    "@workspace/config-tsconfig": "workspace:*",
    "eslint": "^9.39.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
